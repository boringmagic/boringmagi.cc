---
layout: null
---
[
  {% assign feed_items = site.posts | concat: site["case-studies"] | sort: "date" | reverse %}
  {% for item in feed_items %}
    {

      "title"    : "{{ item.title | strip_html | escape }}",
      "description" : "{{ item.description | escape }}",
      "url"      : "{{ site.baseurl }}{{ item.url }}",
      "category" : "{{item.categories | join: ', '}}",
      "tags"     : "{{ item.tags | join: ', ' }}",
      "date"     : "{{ item.date }}"

    } {% unless forloop.last %},{% endunless %}
  {% endfor %}
]
